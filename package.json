  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"const {spawn}=require('child_process'); const env={...process.env, DEBUG:''}; const p=spawn('next',['dev'],{stdio:'inherit',shell:true,env}); p.on('exit',c=>process.exit(c??0));\"",
